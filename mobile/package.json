{
  "name": "riq-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "assets": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\generate-mobile-brand-assets.ps1",
    "dev": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "build:android": "npx eas-cli build -p android --profile production",
    "build:ios": "npx eas-cli build -p ios --profile production",
    "build:preview:android": "npx eas-cli build -p android --profile preview",
    "submit:android": "npx eas-cli submit -p android --latest",
    "submit:ios": "npx eas-cli submit -p ios --latest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@riq/shared": "file:../packages/shared",
    "@supabase/supabase-js": "^2.103.3",
    "expo": "^55.0.14",
    "expo-image": "^55.0.8",
    "expo-linking": "^55.0.12",
    "expo-location": "^55.1.8",
    "expo-router": "^55.0.12",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "^55.0.5",
    "i18next": "^25.10.4",
    "react": "19.2.0",
    "react-i18next": "^16.6.1",
    "react-native": "0.83.4",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^55.0.17",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.15",
    "typescript": "~5.9.3"
  }
}
